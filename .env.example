# Copy to `.env` and fill in your Supabase project credentials.
# Both vars MUST be prefixed EXPO_PUBLIC_ to be bundled into the client.
# These are public-by-design — security lives in Row-Level Security policies
# on the database, not in hiding the anon key.
EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY
